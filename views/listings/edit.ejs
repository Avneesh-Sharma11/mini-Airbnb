<% layout("layouts/boilerplate") -%>

<div class="container ">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card  p-4">
                
                <h2 class="text-center mb-4"><%= user.tital %></h2>
                <p class="text-center text-muted">Profile ID: <%= user._id %></p>

                <form method="post" action="/listings/<%= user._id %>?_method=PUT">

                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input 
                            type="text" 
                            id="title" 
                            name="tital" 
                            class="form-control" 
                            value="<%= user.tital %>"
                        >
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">Image URL</label>
                        <input 
                            type="text" 
                            id="image" 
                            name="image" 
                            class="form-control"
                            value="<%= user.image %>"
                        >
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea 
                            id="description" 
                            name="description" 
                            class="form-control" 
                            rows="3"><%= user.description %></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input 
                            type="text" 
                            id="location" 
                            name="location" 
                            class="form-control"
                            value="<%= user.location %>"
                        >
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-dark" type="submit">
                            Update Listing
                        </button>
                    </div>

                </form>

            </div>

        </div>
    </div>
</div>